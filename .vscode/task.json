{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Собрать QR проект",
            "command": "/usr/bin/g++",
            "args": [
                "-g",
                "${workspaceFolder}/qr_class.cpp",
                "${workspaceFolder}/encode.cpp",
                "-o",
                "${workspaceFolder}/a.out"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}